{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://community-taste-engine.local/schemas/judgement_feedback.schema.json",
  "title": "Judgement Feedback Batch",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "items"
  ],
  "properties": {
    "batch_name": {
      "type": "string"
    },
    "items": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "candidate_id",
          "human_status",
          "human_recommended_action"
        ],
        "properties": {
          "candidate_id": {
            "type": "string",
            "minLength": 1
          },
          "human_status": {
            "enum": [
              "strong_signal",
              "needs_work",
              "unclear",
              "probably_noise"
            ]
          },
          "human_recommended_action": {
            "enum": [
              "feature",
              "refine",
              "clarify",
              "pass"
            ]
          },
          "notes": {
            "type": "string"
          }
        }
      }
    }
  }
}